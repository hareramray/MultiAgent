# --- Provider API keys (set the ones you actually use) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
# GEMINI_API_KEY=...  # alternative name accepted by ADK

# --- Per-reviewer model selection (defaults shown) ---
DOCUMENT_EXTRACTOR_MODEL=gemini-2.5-flash

OPENAI_REVIEWER_PROVIDER=openai
OPENAI_REVIEWER_MODEL=gpt-4o-mini

ANTHROPIC_REVIEWER_PROVIDER=anthropic
ANTHROPIC_REVIEWER_MODEL=claude-sonnet-4-6

GEMINI_REVIEWER_PROVIDER=gemini
GEMINI_REVIEWER_MODEL=gemini-2.0-flash

# --- Synthesizer (merges the three rubrics) ---
SYNTHESIZER_PROVIDER=anthropic
SYNTHESIZER_MODEL=claude-sonnet-4-6
