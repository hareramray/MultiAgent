# Provider + model for the model callback demo agent.
# Providers: gemini | openai | anthropic | ollama
MODEL_CALLBACK_PROVIDER=gemini
MODEL_CALLBACK_MODEL=gemini-2.5-flash

# Simple cost-control thresholds checked by before_model_callback.
MODEL_CALLBACK_MAX_PROMPT_CHARS=700
MODEL_CALLBACK_MAX_PROMPT_TOKENS=220
MODEL_CALLBACK_MAX_MODEL_CALLS_PER_SESSION=2

# When true, after_model_callback appends a visible cost note to real LLM replies.
MODEL_CALLBACK_APPEND_AUDIT_NOTE=true

# API keys: set only the providers you use.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
